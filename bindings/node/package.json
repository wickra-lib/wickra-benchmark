{
  "name": "wickra-benchmark",
  "version": "0.1.0",
  "description": "A reproducible, golden-verified benchmark suite for quant backtests: recompute a curated case or suite with the deterministic Wickra engine and confirm its report and hash. Node bindings powered by Rust.",
  "author": "kingchenc <support@wickra.org>",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "MIT OR Apache-2.0",
  "keywords": [
    "trading",
    "backtest",
    "benchmark",
    "determinism",
    "reproducibility",
    "rust"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/wickra-lib/wickra-benchmark"
  },
  "bugs": {
    "url": "https://github.com/wickra-lib/wickra-benchmark/issues"
  },
  "homepage": "https://github.com/wickra-lib/wickra-benchmark",
  "files": [
    "index.js",
    "index.d.ts",
    "npm",
    "*.node"
  ],
  "napi": {
    "name": "wickra-benchmark",
    "triples": {
      "defaults": false,
      "additional": [
        "x86_64-unknown-linux-gnu",
        "aarch64-unknown-linux-gnu",
        "x86_64-apple-darwin",
        "aarch64-apple-darwin",
        "x86_64-pc-windows-msvc",
        "aarch64-pc-windows-msvc"
      ]
    }
  },
  "engines": {
    "node": ">= 22"
  },
  "optionalDependencies": {
    "wickra-benchmark-linux-x64-gnu": "0.1.0",
    "wickra-benchmark-linux-arm64-gnu": "0.1.0",
    "wickra-benchmark-darwin-x64": "0.1.0",
    "wickra-benchmark-darwin-arm64": "0.1.0",
    "wickra-benchmark-win32-x64-msvc": "0.1.0",
    "wickra-benchmark-win32-arm64-msvc": "0.1.0"
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "artifacts": "napi artifacts",
    "version": "napi version",
    "test": "node --test"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.7.2"
  }
}
